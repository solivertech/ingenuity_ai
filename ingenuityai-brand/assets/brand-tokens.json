{
  "brand": {
    "name": "IngenuityAI",
    "tagline": "Autonomous Web Intelligence",
    "domain": "ingenuityai.app"
  },
  "colors": {
    "teal": {
      "900": "#04342C",
      "800": "#085041",
      "700": "#0A5C45",
      "600": "#0F6E56",
      "500": "#0F8F6E",
      "400": "#1DB88E",
      "300": "#3DC49A",
      "200": "#5DCAA5",
      "100": "#9FE1CB",
      "50":  "#E1F5EE"
    },
    "neutral": {
      "ink":   "#111110",
      "slate": "#444441",
      "muted": "#888780",
      "stone": "#F1EFE8",
      "white": "#ffffff"
    },
    "brand": {
      "primary":    "#0F8F6E",
      "primaryDark":"#063D2E",
      "accent":     "#1DB88E",
      "accentLight":"#5DCAA5",
      "wash":       "#E1F5EE"
    },
    "semantic": {
      "success": "#0F8F6E",
      "warning": "#EF9F27",
      "danger":  "#E24B4A",
      "info":    "#185FA5"
    }
  },
  "typography": {
    "fontStack": {
      "sans": "-apple-system, 'Helvetica Neue', Arial, sans-serif",
      "mono": "'SF Mono', 'Fira Code', 'Consolas', monospace"
    },
    "scale": {
      "display": { "size": "52px", "weight": 300, "tracking": "-1.5px", "usage": "Hero wordmark only" },
      "h1":      { "size": "32px", "weight": 400, "tracking": "-0.5px", "usage": "Page titles" },
      "h2":      { "size": "22px", "weight": 500, "tracking": "0",      "usage": "Section headings" },
      "h3":      { "size": "17px", "weight": 500, "tracking": "0",      "usage": "Card headings" },
      "body":    { "size": "15px", "weight": 400, "lineHeight": "1.6",  "usage": "Body copy" },
      "label":   { "size": "11px", "weight": 500, "tracking": "0.08em", "transform": "uppercase", "usage": "UI labels, section dividers" },
      "code":    { "size": "13px", "weight": 400, "font": "mono",       "usage": "Code, domains, technical strings" }
    }
  },
  "spacing": {
    "4":  "4px",
    "8":  "8px",
    "16": "16px",
    "24": "24px",
    "48": "48px",
    "80": "80px"
  },
  "borderRadius": {
    "subtle": "4px",
    "default": "8px",
    "card":    "12px",
    "large":   "16px",
    "pill":    "9999px"
  },
  "borders": {
    "thin":     "0.5px solid #D3D1C7",
    "medium":   "1px solid #B4B2A9",
    "accent":   "1.5px solid #0F8F6E",
    "featured": "2px solid #0F8F6E"
  },
  "shadows": {
    "none":  "none",
    "focus": "0 0 0 3px rgba(15, 143, 110, 0.25)"
  },
  "components": {
    "buttons": {
      "primary":   { "bg": "#063D2E", "text": "#E1F5EE", "border": "none",                   "radius": "8px", "padding": "10px 22px", "fontSize": "13px", "fontWeight": 500 },
      "outline":   { "bg": "transparent", "text": "#0F8F6E", "border": "1.5px solid #0F8F6E","radius": "8px", "padding": "9px 22px",  "fontSize": "13px", "fontWeight": 500 },
      "ghost":     { "bg": "#F1EFE8",     "text": "#444441", "border": "0.5px solid #D3D1C7","radius": "8px", "padding": "9px 22px",  "fontSize": "13px", "fontWeight": 400 }
    },
    "pills": {
      "active":  { "bg": "#E1F5EE", "text": "#085041" },
      "paused":  { "bg": "#FAEEDA", "text": "#633806" },
      "error":   { "bg": "#FCEBEB", "text": "#791F1F" },
      "neutral": { "bg": "#F1EFE8", "text": "#444441", "border": "0.5px solid #D3D1C7" }
    },
    "input": {
      "border":       "1px solid #D3D1C7",
      "borderFocus":  "1px solid #0F8F6E",
      "radius":       "8px",
      "padding":      "11px 16px",
      "fontSize":     "14px",
      "shadow":       "0 0 0 3px rgba(15, 143, 110, 0.15)"
    }
  },
  "logo": {
    "files": {
      "iconMark":      "icons/icon-mark.svg",
      "appIcon512":    "icons/app-icon-512.svg",
      "wordmarkLight": "logos/wordmark-light.svg",
      "wordmarkDark":  "logos/wordmark-dark.svg"
    },
    "clearspace":        "Equal to the height of the rotor mark on all sides",
    "minWordmarkWidth":  "120px",
    "minIconSize":       "24px",
    "backgroundsAllowed":["#063D2E (forest dark)", "#ffffff (white)", "#F1EFE8 (stone)"],
    "rules": [
      "Never recolor the mark outside the brand palette",
      "Never add drop shadows, outlines, or glow effects",
      "Never stretch or distort proportions",
      "Use the contained app icon for favicons and app icons",
      "AI suffix is always teal — never match it to the Ingenuity weight color"
    ]
  },
  "voice": {
    "principles": [
      "Precise, not jargon-heavy — say what it does in plain language",
      "Confident, not boastful — avoid superlatives",
      "Human, not robotic — write for a smart friend, not a press release",
      "Active voice always — IngenuityAI does things, things are not done by it"
    ]
  }
}
