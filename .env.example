ANTHROPIC_API_KEY=

# Ollama servers — add up to two hosts (host:port).
# At startup the tracker probes both and routes to whichever performs better.
# OLLAMA_NETWORK_HOST=192.168.0.206:11434
# OLLAMA_NETWORK_HOST_2=192.168.0.232:11434

# Gmail API
# Step 1 — fill in GMAIL_SENDER, GMAIL_CLIENT_ID, GMAIL_CLIENT_SECRET:
#   console.cloud.google.com → APIs & Services → Credentials
#   → Create Credentials → OAuth client ID → Desktop app
#   Client ID and Client Secret are shown there; paste them below.
GMAIL_SENDER=you@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Step 2 — run:  python setup_gmail_oauth.py
#   That script opens a browser, you authorize the app, and it writes
#   GMAIL_REFRESH_TOKEN here automatically. Do not fill it in by hand.
GMAIL_REFRESH_TOKEN=

EMAIL_FROM_NAME=IngenuityAI

# Twilio SMS alerts (optional)
# Create a free account at twilio.com, then fill in these three values.
# Add sms_to: ["+15555550100"] to any profile in profiles.yaml to activate.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
